<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "用户中心 - KivExpress" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen flex flex-col">
    <%= render 'shared/navbar' %>

    <div class="flex flex-1 overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-64 bg-white border-r border-gray-200 hidden md:block">
        <div class="flex flex-col h-full py-6">
          <div class="px-6 mb-8">
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">用户后台</h2>
          </div>
          
          <nav class="flex-1 px-4 space-y-1">
            <%= link_to new_dashboard_order_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'orders' && action_name == 'new' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
              在线下单
            <% end %>

            <%= link_to dashboard_orders_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'orders' && action_name == 'index' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
              我的订单
            <% end %>

            <div class="pt-4 pb-2">
              <div class="h-px bg-gray-200"></div>
            </div>

            <%= link_to dashboard_warehouse_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'dashboard' && action_name == 'warehouse' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              转运仓库
            <% end %>

            <%= link_to dashboard_addresses_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'addresses' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              地址管理
            <% end %>

            <div class="pt-4 pb-2">
              <div class="h-px bg-gray-200"></div>
            </div>

            <%= link_to dashboard_profile_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'dashboard' && action_name == 'profile' ? 'bg-primary text-white' : 'text-gray-600 hover:bg-gray-50'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              个人信息
            <% end %>

            <%= link_to edit_user_registration_path, class: "flex items-center px-4 py-2 text-sm font-medium text-gray-600 rounded-lg hover:bg-gray-50" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
              修改密码
            <% end %>

            <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center px-4 py-2 text-sm font-medium text-red-600 rounded-lg hover:bg-red-50 transition-colors" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
              退出登录
            <% end %>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto p-4 md:p-8">
        <div class="max-w-4xl mx-auto">
          <% if notice %>
            <div class="mb-4 p-4 text-sm text-green-700 bg-green-100 rounded-lg" role="alert">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div class="mb-4 p-4 text-sm text-red-700 bg-red-100 rounded-lg" role="alert">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>

    <%= render 'shared/footer' %>
  </body>
</html>