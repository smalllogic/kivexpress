<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "管理后台 - KivExpress" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen flex flex-col">
    <%= render 'shared/navbar' %>

    <div class="flex flex-1 overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-64 bg-slate-800 text-white hidden md:block">
        <div class="flex flex-col h-full py-6">
          <div class="px-6 mb-8">
            <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">管理系统</h2>
          </div>
          
          <nav class="flex-1 px-4 space-y-1">
            <%= link_to admin_root_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'dashboard' ? 'bg-primary text-white' : 'text-slate-300 hover:bg-slate-700'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
              仪表盘
            <% end %>

            <%= link_to admin_orders_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'orders' ? 'bg-primary text-white' : 'text-slate-300 hover:bg-slate-700'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
              管理订单
            <% end %>

            <%= link_to admin_users_path, class: "flex items-center px-4 py-2 text-sm font-medium rounded-lg #{controller_name == 'users' ? 'bg-primary text-white' : 'text-slate-300 hover:bg-slate-700'}" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              所有用户
            <% end %>

            <div class="pt-4 pb-2">
              <div class="h-px bg-slate-700"></div>
            </div>

            <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center px-4 py-2 text-sm font-medium text-red-400 rounded-lg hover:bg-slate-700 transition-colors" do %>
              <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
              退出登录
            <% end %>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto p-4 md:p-8">
        <div class="max-w-6xl mx-auto">
          <% if notice %>
            <div class="mb-4 p-4 text-sm text-green-700 bg-green-100 rounded-lg" role="alert">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div class="mb-4 p-4 text-sm text-red-700 bg-red-100 rounded-lg" role="alert">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>

    <%= render 'shared/footer' %>
  </body>
</html>
