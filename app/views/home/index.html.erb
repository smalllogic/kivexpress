            <% end %>
          </div>
          
          <!-- CTA Buttons -->
          <div class="mt-10 flex flex-col sm:flex-row justify-center lg:justify-start space-y-4 sm:space-y-0 sm:space-x-4">
            <div class="rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:scale-105">
              <%= link_to "立即注册", new_user_registration_path, class: "w-full flex items-center justify-center px-8 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-secondary hover:bg-secondary/90 md:py-4 md:text-lg md:px-10 shadow-md" %>
