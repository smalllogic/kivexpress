            <%= form_with url: track_path, method: :get, local: true, class: "w-full max-w-md bg-white rounded-xl p-2 border border-gray-200 flex shadow-lg hover:shadow-xl transition-shadow" do |f| %>
              <%= text_field_tag :q, nil, placeholder: "请输入物流单号...", class: "flex-grow px-5 py-3 bg-transparent focus:outline-none text-gray-700 placeholder-gray-400 min-w-0" %>
