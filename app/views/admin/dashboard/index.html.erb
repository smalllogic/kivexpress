<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
  <h1 class="text-3xl font-bold text-gray-900 mb-4">欢迎回来，管理员</h1>
  <p class="text-gray-600">这是您的管理后台仪表盘。</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
    <h3 class="text-gray-500 text-sm font-medium uppercase">待处理订单</h3>
    <p class="text-3xl font-bold text-primary mt-2">0</p>
  </div>
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
    <h3 class="text-gray-500 text-sm font-medium uppercase">总用户数</h3>
    <p class="text-3xl font-bold text-secondary mt-2"><%= User.count %></p>
  </div>
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
    <h3 class="text-gray-500 text-sm font-medium uppercase">今日包裹</h3>
    <p class="text-3xl font-bold text-green-600 mt-2">0</p>
  </div>
</div>
