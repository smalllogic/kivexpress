<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="p-8">
    <div class="flex items-center space-x-4 mb-6">
      <div class="bg-primary/10 p-3 rounded-full">
        <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">欢迎回来，<%= current_user.email %></h1>
        <p class="text-gray-500">这是您的用户控制面板，您可以在这里管理您的包裹、订单和个人信息。</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <div class="border border-gray-100 rounded-lg p-6 bg-gray-50 hover:bg-white hover:shadow-md transition-all cursor-pointer">
        <h3 class="font-bold text-lg text-gray-800 mb-2">待处理包裹</h3>
        <p class="text-3xl font-extrabold text-primary">0</p>
        <p class="text-sm text-gray-500 mt-2">目前没有需要您处理的包裹</p>
      </div>
      
      <div class="border border-gray-100 rounded-lg p-6 bg-gray-50 hover:bg-white hover:shadow-md transition-all cursor-pointer">
        <h3 class="font-bold text-lg text-gray-800 mb-2">进行中的订单</h3>
        <p class="text-3xl font-extrabold text-secondary">0</p>
        <p class="text-sm text-gray-500 mt-2">目前没有正在进行的转运订单</p>
      </div>
    </div>
  </div>
</div>
