<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">个人信息</h1>
  <div class="space-y-4">
    <div class="flex border-b pb-2">
      <span class="w-32 text-gray-500">电子邮箱：</span>
      <span class="font-medium"><%= current_user.email %></span>
    </div>
    <div class="flex border-b pb-2">
      <span class="w-32 text-gray-500">账号状态：</span>
      <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">正常</span>
    </div>
    <div class="pt-4">
      <%= link_to "修改个人资料", edit_user_registration_path, class: "text-primary hover:underline font-medium" %>
    </div>
  </div>
</div>
