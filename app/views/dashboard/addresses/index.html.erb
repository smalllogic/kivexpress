<div class="bg-white rounded-xl shadow-sm border border-gray-200">
  <div class="p-6 border-b border-gray-200 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">地址管理</h1>
    <%= link_to new_dashboard_address_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary hover:bg-primary/90 focus:outline-none transition-colors" do %>
      <svg class="mr-2 -ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
      添加新地址
    <% end %>
  </div>

  <div class="p-6">
    <% if @addresses.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @addresses.each do |address| %>
          <div class="border border-gray-200 rounded-lg p-5 hover:border-primary transition-colors relative group">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-lg font-bold text-gray-900"><%= address.contact_name %></h3>
                <p class="text-sm text-gray-500"><%= address.phone %></p>
              </div>
              <div class="flex space-x-2">
                <%= link_to edit_dashboard_address_path(address), class: "p-2 text-gray-400 hover:text-primary transition-colors" do %>
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                <% end %>
                <%= button_to dashboard_address_path(address), method: :delete, data: { turbo_confirm: "确定要删除这个地址吗？" }, class: "p-2 text-gray-400 hover:text-red-500 transition-colors" do %>
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                <% end %>
              </div>
            </div>
            <div class="space-y-2 text-sm text-gray-600">
              <p><span class="font-medium text-gray-900">地址：</span><%= "#{address.country} #{address.province} #{address.city} #{address.district}" %></p>
              <p class="pl-12"><%= address.detail_address %></p>
              <% if address.alt_phone.present? %>
                <p><span class="font-medium text-gray-900">备用电话：</span><%= address.alt_phone %></p>
              <% end %>
              <% if address.email.present? %>
                <p><span class="font-medium text-gray-900">电子邮件：</span><%= address.email %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">暂无地址</h3>
        <p class="mt-1 text-sm text-gray-500">点击下方按钮添加您的第一个转运地址。</p>
        <div class="mt-6">
          <%= link_to new_dashboard_address_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-primary hover:bg-primary/90 focus:outline-none" do %>
            添加新地址
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
