<%= form_with(model: [:dashboard, address], class: "space-y-6") do |f| %>
  <% if address.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">存在以下错误，无法保存地址：</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% address.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :contact_name, "责任人姓名 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :contact_name, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :phone, "手机联系方式 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :phone, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :alt_phone, "应急手机联系方式", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :alt_phone, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :email, "电子邮件", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 pt-4 border-t border-gray-100">
    <div>
      <%= f.label :country, "国家 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :country, value: address.country || "中国", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :province, "省 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :province, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :city, "市 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :city, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :district, "区 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :district, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :detail_address, "具体门牌地址 *", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :detail_address, rows: 3, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" %>
  </div>

  <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200">
    <%= link_to "取消", dashboard_addresses_path, class: "inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none" %>
    <%= f.submit "保存地址", class: "inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary cursor-pointer transition-colors" %>
  </div>
<% end %>
