<nav class="bg-white border-b border-gray-200" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center">
        <!-- 移动端菜单按钮 -->
        <div class="flex items-center lg:hidden mr-2">
          <button type="button" 
                  class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary"
                  aria-controls="mobile-menu" 
                  aria-expanded="false"
                  data-action="click->navbar#toggle">
            <span class="sr-only">打开主菜单</span>
            <!-- 汉堡按钮图标 -->
            <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" data-navbar-target="openIcon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <!-- 关闭按钮图标 (X) -->
            <svg class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" data-navbar-target="closeIcon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <%= link_to root_path, class: "flex-shrink-0 flex items-center" do %>
          <%= image_tag "kivexpress.png", alt: "Logo", class: "h-8 sm:h-10 w-auto" %>
        <% end %>
        <div class="hidden lg:ml-6 lg:flex lg:space-x-4">
          <%= link_to "首页", root_path, class: "border-primary text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium" %>
          <%= link_to "物流预订", new_dashboard_order_path, class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <%= link_to "产品服务", "#", class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <%= link_to "服务网点", "#", class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <%= link_to "运单查询", track_path, class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <%= link_to "帮助中心", "#", class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <%= link_to "加盟合作", "#", class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <% if user_signed_in? %>
            <% if current_user.admin? %>
              <%= link_to "后台管理", admin_root_path, class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
            <% end %>
            <%= link_to "用户中心", dashboard_path, class: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium whitespace-nowrap" %>
          <% end %>
        </div>
      </div>
      <div class="flex items-center space-x-4">
        <% if user_signed_in? %>
          <span class="text-sm text-gray-700"><%= current_user.email %></span>
          <% if current_user.admin? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary/10 text-secondary">管理员</span>
          <% end %>
          <%= button_to "退出登录", destroy_user_session_path, method: :delete, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary hover:bg-primary/90 focus:outline-none" %>
        <% else %>
          <%= link_to "登录", new_user_session_path, class: "text-gray-500 hover:text-gray-700 text-sm font-medium" %>
          <%= link_to "注册", new_user_registration_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-secondary hover:bg-secondary/90 focus:outline-none" %>
        <% end %>
      </div>
    </div>
  </div>
  <!-- 移动端菜单面板 -->
  <div class="hidden lg:hidden bg-white border-t border-gray-100 shadow-xl" id="mobile-menu" data-navbar-target="mobileMenu">
    <div class="px-2 pt-2 pb-3 space-y-1">
      <%= link_to "首页", root_path, class: "bg-primary/10 text-primary block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "物流预订", new_dashboard_order_path, class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "产品服务", "#", class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "服务网点", "#", class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "运单查询", track_path, class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "帮助中心", "#", class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "加盟合作", "#", class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      
      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <%= link_to "后台管理", admin_root_path, class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
        <% end %>
        <%= link_to "用户中心", dashboard_path, class: "text-gray-600 hover:bg-gray-50 hover:text-gray-900 block px-3 py-2 rounded-md text-base font-medium" %>
      <% end %>
    </div>
    <div class="pt-4 pb-3 border-t border-gray-200">
      <% if user_signed_in? %>
        <div class="flex items-center px-4">
          <div class="flex-shrink-0">
            <div class="h-10 w-10 rounded-full bg-primary flex items-center justify-center text-white">
              <%= current_user.email[0].upcase %>
            </div>
          </div>
          <div class="ml-3">
            <div class="text-base font-medium text-gray-800"><%= current_user.email %></div>
          </div>
        </div>
        <div class="mt-3 px-2 space-y-1">
          <%= button_to "退出登录", destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900" %>
        </div>
      <% else %>
        <div class="mt-3 px-2 space-y-1">
          <%= link_to "登录", new_user_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900" %>
          <%= link_to "注册", new_user_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-white bg-secondary hover:bg-secondary/90" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
